# Copy to .env and fill in real values. docker compose reads .env automatically. NEVER commit .env.
# The SAME secret must be used by user-service and journal-service (>= 32 bytes for HS256).
JWT_SECRET=change-this-to-a-long-random-secret-of-at-least-32-bytes
JWT_EXPIRATION=3600000

# MongoDB connection string (required - there is no default). Used by user-service and journal-service.
# Include the database name "/journaldb" before the "?", and URL-encode special chars in the password.
MONGODB_URI=mongodb+srv://<username>:<db_password>@<your-cluster-host>/journaldb?retryWrites=true&w=majority
